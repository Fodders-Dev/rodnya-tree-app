<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Разрешения -->
    <!-- Разрешение для WorkManager для перезапуска задач после перезагрузки -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- Разрешение на показ уведомлений (необходимо для Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Нужен для полноэкранного входящего звонка -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>
    <!-- Разрешение на вибрацию для уведомлений (если используется) -->
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- Интернет нужен для синхронизации -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Микрофон нужен для голосовых и звонков -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Камера нужна для видеозвонков и видеосообщений -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Улучшает управление аудиотрактом во время звонков -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <!-- Нужен для self-managed Android Telecom входящих звонков -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS"/>
    <!-- Контакты нужны для поиска родственников по телефонной книге -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <!-- Доступ к состоянию сети нужен WorkManager для ограничений по сети -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Разрешение WAKE_LOCK может помочь для надежности фоновых задач -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Позволяет запросить системное исключение из оптимизации батареи:
         критично для фоновых входящих звонков на агрессивных прошивках. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- U3: OTA-самообновление sideload-сборок (раздача через Telegram,
         вне магазина). Нужно для запуска системного установщика на
         скачанный APK. Уровень normal, на API <26 игнорируется.
         FileProvider для content://-доступа к APK предоставляет
         open_filex (authority ${applicationId}.fileProvider...). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Foreground service для активного звонка (Bug A audit 2026-05-22):
         Android 14+ требует FOREGROUND_SERVICE + foregroundServiceType
         декларацию, иначе mic capture revokes когда screen blank / app
         backgrounded — producer audio drops silently, собеседник не
         слышит. Это не device quirk, это documented Android behavior
         change. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Bluetooth (Bug B audit 2026-05-22): user'у нужно использовать
         BT-гарнитуру во время звонка. Без BLUETOOTH_CONNECT runtime
         permission на Android 12+ (API 31+), system silently rejects
         enumeration paired devices и audio routing fallback'ается на
         speaker/earpiece. Legacy BLUETOOTH + BLUETOOTH_ADMIN — для
         backward compat на API ≤ 30 (no runtime grant).
         BLUETOOTH_SCAN — для discovery новых devices; мы только
         enumerate уже-paired, поэтому neverForLocation hint избегает
         coarse location grant. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" tools:targetApi="s" />
    <!-- OEM autostart deep-link (Huawei «Запуск приложений» /
         «Защищённые приложения»). EMUI's systemmanager autostart activities
         (com.huawei.systemmanager.startupmgr/appcontrol/optimize) are
         component-protected by this permission. Объявляем его, чтобы
         deep-link срабатывал там, где permission грантится.

         РЕАЛЬНОСТЬ (проверено на HUAWEI TGR-W09 / HarmonyOS на базе
         Android 12): здесь protectionLevel = signature|privileged, поэтому
         sideload-сборке (подписанной нашим ключом, не системным) он НЕ
         грантится — startActivity в эти экраны ловит «Permission Denial …
         requires …USE_COMPONENT», и мы корректно уходим в фолбэк (общие
         настройки приложения). На более старых EMUI этот permission бывает
         normal-level / активности экспортированы — там deep-link открывается
         напрямую. Декларация безопасна: на не-Huawei и там, где не грантится,
         просто игнорируется (не dangerous → без рантайм-промпта). -->
    <uses-permission android:name="com.huawei.permission.external_app_settings.USE_COMPONENT" />

    <application
        android:label="Родня"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:allowBackup="true">
        <meta-data
            android:name="rodnya.notification.icon"
            android:resource="@drawable/ic_stat_notification" />
        <service
            android:name=".RodnyaConnectionService"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <!-- Foreground service для активного звонка. Запускается из
             Dart side (CallCoordinatorService) когда call transitions
             в state=active, останавливается на terminal/disconnected.
             foregroundServiceType="microphone" — обязательно для
             Android 14+ чтобы mic capture не revoked OS-ью. См.
             escalation-2026-05-22.md / Bug A. -->
        <service
            android:name=".RodnyaCallForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Replace the plugin's default messaging service with our own
             subclass. The plugin's class is `final` (not extendable
             from app code); the underlying RuStoreMessagingService
             only allows ONE registered service for the
             `MESSAGING_EVENT` intent filter, so we drop the plugin's
             entry from the merged manifest and register ours below.
             Our service still forwards every push to the plugin's
             pigeon callback (FlutterRustorePushService.client) so the
             Dart-side onMessageReceived listener keeps firing
             unchanged when the engine is alive. -->
        <service
            android:name="ru.rustore.flutter_rustore_push.FlutterRustorePushService"
            tools:node="remove" />

        <service
            android:name="com.ahjkuio.rodnya_family_app.RodnyaPushService"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="ru.rustore.sdk.pushclient.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/LaunchTheme"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Добавляем Intent Filter для Deep Link биллинга -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="rodnyabilling"/>
            </intent-filter>

            <!-- OAuth callback deep link (Telegram / VK ID / MAX).
                 Custom-scheme fallback for older builds and devices
                 that haven't picked up the verified App Links yet.
                 Any other app can technically register the same
                 `rodnya://` scheme, so the verified-https filter
                 below is preferred when both are available. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="rodnya"
                    android:host="oauth"/>
            </intent-filter>

            <!-- Verified App Links — closes the OAuth deep-link
                 spoofing hole. android:autoVerify="true" tells the
                 OS to fetch
                 https://rodnya-tree.ru/.well-known/assetlinks.json
                 on install and grant us EXCLUSIVE ownership of
                 https://rodnya-tree.ru/oauth/callback paths if our
                 SHA-256 cert fingerprint matches the entry there.
                 No other app can intercept these intents (and the
                 chooser dialog never appears). For this to take
                 effect on a real install, assetlinks.json MUST be
                 served from
                 https://rodnya-tree.ru/.well-known/assetlinks.json
                 with `Content-Type: application/json` and the
                 release keystore's SHA-256 fingerprint listed. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https"/>
                <data android:host="rodnya-tree.ru"/>
                <data android:pathPrefix="/oauth/"/>
            </intent-filter>

            <!-- Ship FE3b (2026-05-28): семя invitation deep link
                 (https://rodnya-tree.ru/invite/{token}). Sibling
                 verified-App-Link filter — autoVerify ставит assetlinks.json
                 owner-check тот же, что для /oauth/ блока (release keystore
                 SHA-256 listed once в JSON, covers all path prefixes этого
                 host). NO separate keystore wiring required.

                 Token = one-shot capability secret (backend Ship 4). Тап
                 от email opens app via этот filter, Flutter intercepts
                 path через GoRouter's /invite/:token route, guard
                 persists token + handles login redirect если нужно. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https"/>
                <data android:host="rodnya-tree.ru"/>
                <data android:pathPrefix="/invite/"/>
            </intent-filter>

            <!-- Legacy tree/person invite links are hash-routed:
                 https://rodnya-tree.ru/#/invite?treeId=...&personId=...
                 Android App Links do not match fragments, so the
                 actual path seen by the OS is just "/". This narrow
                 root filter lets installed APKs receive those links;
                 Dart app_links then restores the fragment route and
                 sends it through the existing /invite guard. The
                 /invite path variant keeps older non-hash links
                 app-openable too. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="https"
                    android:host="rodnya-tree.ru"
                    android:path="/"/>
                <data
                    android:scheme="https"
                    android:host="rodnya-tree.ru"
                    android:path="/invite"/>
            </intent-filter>

        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Profile Phase 2b-2 STT spike (2026-05-29): lets speech_to_text
             discover the on-device recognition service on Android 11+.
             Keep if voice ships; remove with the spike if STT is no-go. -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
    </queries>
</manifest>
