<?xml version="1.0" encoding="utf-8"?>
<!-- Status-bar / heads-up notification icon for the Rodnya app.
     Android 5+ renders status icons as alpha masks tinted with the
     channel's accent color, so the icon must be a single-color
     silhouette on a transparent background. We use a stylized tree
     with three nodes connecting through trunk lines — same shape
     family our brand icon uses on the splash / about screen. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Trunk — central vertical stem. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M11.25,9 L11.25,18 L12.75,18 L12.75,9 Z" />
    <!-- Lower branch arms (V shape). -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M6.5,14 L11.25,11.5 L11.25,13 L7.6,14.85 L7.6,17.5 L6.4,17.5 L6.4,14.5 Z" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M17.5,14 L12.75,11.5 L12.75,13 L16.4,14.85 L16.4,17.5 L17.6,17.5 L17.6,14.5 Z" />
    <!-- Three node circles: top crown + two bottom -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,3 m-3.4,0 a3.4,3.4 0 1,0 6.8,0 a3.4,3.4 0 1,0 -6.8,0" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M6.5,18 m-2.6,0 a2.6,2.6 0 1,0 5.2,0 a2.6,2.6 0 1,0 -5.2,0" />
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M17.5,18 m-2.6,0 a2.6,2.6 0 1,0 5.2,0 a2.6,2.6 0 1,0 -5.2,0" />
</vector>
