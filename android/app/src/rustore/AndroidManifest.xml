<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application>
        <meta-data
            android:name="ru.rustore.sdk.ApplicationId"
            android:value="${rustoreApplicationId}" />

        <meta-data
            android:name="ru.rustore.sdk.pushclient.project_id"
            android:value="${rustorePushProjectId}" />

        <!-- Дефолтные пуши, которые рисует сам VKPNS SDK (тестовые из
             консоли, notification-type без нашего сервиса), без этих мет
             берут launcher-иконку — серый невзрачный значок. Фирменный
             силуэт-дерево + бренд-зелёный, как у наших чат-пушей. -->
        <meta-data
            android:name="ru.rustore.sdk.pushclient.default_notification_icon"
            android:resource="@drawable/ic_stat_notification" />
        <meta-data
            android:name="ru.rustore.sdk.pushclient.default_notification_color"
            android:resource="@color/colorAccent" />

        <service
            android:name="ru.rustore.flutter_rustore_push.service.RuStoreMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="ru.rustore.sdk.pushservice.ACTION_PROCESS_MESSAGE" />
            </intent-filter>
        </service>

        <!-- The Google Play photo picker backport service is irrelevant in RuStore builds. -->
        <service
            android:name="com.google.android.gms.metadata.ModuleDependencies"
            tools:node="remove" />
    </application>
</manifest>
