RODNYA_SMOKE_BASE_URL=https://rodnya-tree.ru
RODNYA_SMOKE_API_URL=https://api.rodnya-tree.ru
RODNYA_SMOKE_SUITE=all

# Disposable smoke account for protected routes.
RODNYA_SMOKE_EMAIL=smoke-user@example.com
RODNYA_SMOKE_PASSWORD=replace-me
RODNYA_SMOKE_PARTNER_EMAIL=smoke-partner@example.com
RODNYA_SMOKE_PARTNER_PASSWORD=replace-me-too
RODNYA_SMOKE_DISPLAY_NAME=Rodnya Smoke
RODNYA_SMOKE_TREE_NAME=Rodnya Smoke Tree
RODNYA_SMOKE_AUTO_REGISTER=0
RODNYA_SMOKE_FIXTURE_TREE_ID=
RODNYA_SMOKE_KEEP_FIXTURES=0

# One-time disposable fixtures for invite / claim flows.
# If URLs are left empty and the smoke account has access to a writable tree,
# prod_route_smoke.mjs will auto-create a temporary offline person fixture,
# a relative-details route, and a disposable chat route when possible.
RODNYA_SMOKE_INVITE_URL=https://rodnya-tree.ru/#/invite?treeId=replace&personId=replace
RODNYA_SMOKE_CLAIM_URL=https://rodnya-tree.ru/#/invite?treeId=replace&personId=replace&claim=1

# Optional moderator/admin account for /v1/admin/runtime checks.
RODNYA_RUNTIME_EMAIL=runtime-admin@example.com
RODNYA_RUNTIME_PASSWORD=replace-me
RODNYA_RUNTIME_ALERT_WEBHOOK_URL=
